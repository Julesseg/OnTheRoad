# Copy to .env.local and fill in. .env*.local is gitignored.
# Apple Developer Team ID — used by app.config.js for iOS / share-extension
# signing. Find it at https://developer.apple.com/account (Membership details).
APPLE_TEAM_ID=
# Google Maps SDK for Android key — used by app.config.js to render GoogleMaps.View
# on Android (ADR-0015). Create a key with the "Maps SDK for Android" API enabled
# at https://console.cloud.google.com/google/maps-apis. Map rendering is free.
GOOGLE_MAPS_API_KEY=
